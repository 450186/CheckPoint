<div id="game-modal" class="modal-overlay" aria-hidden="true">
  <div class="modal" role="dialog" aria-modal="true" aria-labelledby="modal-title" aria-describedby="modal-info">
    <div class="modal-body">
      <img id="modal-cover" class="modal-cover" src="" alt="" />

      <div class="modal-info">
        <div class="modal-header">
          <h2 id="modal-title"></h2>
          <button class="modal-close" type="button" aria-label="Close dialog">×</button>
        </div>

        <p id="modal-info" class="muted-text"></p>
        <p id="modal-genres"></p>
        <p id="modal-rating"></p>

        <div class="card-spacer"></div>

        <div class="modal-actions">
          <form action="/library/add" method="POST" class="library-form">
            <input type="hidden" name="gameId" value="">
            <input type="hidden" name="name" value="">
            <input type="hidden" name="coverUrl" value="">
            <input type="hidden" name="status" value="wishlist">
            <button type="submit" class="add-btn">+ Add to Library</button>
            <a href="/game" id="modal-go-to-game" class="go-to-game">Go to Game</a>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
