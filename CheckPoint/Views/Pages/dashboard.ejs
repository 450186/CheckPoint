<%- include('../Partials/header') %>
<div class="sidebar">
    <ul class="nav-list">
        <li class="nav-item active-link"><a href="/dashboard">
                <%= title %>
            </a></li>
        <li class="nav-item"><a href="/discover">Discover</a></li>
        <li class="nav-item"><a href="/library">My Library</a></li>
        <li class="nav-item logout"><a href="/logout">Logout</a></li>
    </ul>
</div>
<div class="main-content">
    <h2 class="title">
        <%= title %>
    </h2>
    <div class="welcome-message">
        <h3>Welcome back,
            <%= user.firstName %>!
        </h3>
    </div>
    <div class="card-rows">
        <div class="dash-card">
            <h3>Your Stats</h3>
            <p>Your key stats below:</p>
            <p class="stats-list"> <i class="fa-solid fa-gamepad"></i> <i
                    class="fa-solid fa-gamepad"></i> <i
                    class="fa-solid fa-gamepad"></i> </p>
            <div class="card-spacer"></div>
        </div>
        <div class="dash-card review-card">
            <h3>Your Reviews</h3>
            <p>See your most recent reviews here</p>
            <% if (YourReviews.length === 0) { %>
                <p class="no-items">Review games you've played for them to appear here</p>
            <% } %>
            <% if(YourReviews.length) { %>
                <div class="review-container">
                    <div class="slideshow-container" id="reviews-slideshow">
                        <% YourReviews.forEach((review, index) => { %>
                            <div class="review-slide"
                                style="<%= index === 0 ? 'display:block;' : 'display:none;' %>"
                            >
                                <div class="review-header">
                                    <div class="review-header-text">
                                        <p style="font-weight: bold; font-size: 1.2rem" class="review-game"><%= review.cachedName %></p>
                                        <p style="font-weight: bold;" class="review-title"><%= review.title %></p>
                                    </div>
                                    <img class="review-img-small" src="<%= review.cachedCoverUrl.replace('t_cover_big', 't_thumb') %>" alt="<%= review.cachedName %>">
                                </div>
                                <p class="review-body"><%= review.body %></p>
                            </div> 
                        <% }) %>
                    </div>
                    <div class="review-controls">
                        <% if (YourReviews.length > 1) { %>
                            <a class="reviewPrev" onclick="plusReviewSlides(-1)">&#10094;</a>
                        <% } %>
                    <div class="dot-div">
                        <% YourReviews.forEach((_, index) => { %>
                            <span class="reviewDot <%= index === 0 ? 'active' : '' %>" onclick="currentReviewSlide(<%= index + 1 %>)"></span>
                        <% }) %>
                    </div>
                    <% if (YourReviews.length > 1) { %>
                        <a class="reviewNext" onclick="plusReviewSlides(1)">&#10095;</a>
                    <% } %>
                    </div>
                </div>
            <% } %>
            <div class="card-spacer"></div>
            <div class="go-to-reviews">
                <button class="add-btn" type="button" onclick="window.location.href='/your-reviews'">View all of your reviews</button>
            </div>
        </div>
        <div class="dash-card">
            <h3>Highest Rated</h3>
            <p>Your highest rated games</p>
            <p class="highest-rated"> <i class="fa-solid fa-gamepad"></i> <i
                    class="fa-solid fa-gamepad"></i> <i
                    class="fa-solid fa-gamepad"></i> </p>
            <div class="card-spacer"></div>
        </div>
    </div>
    <div class="card-rows">
        <div class="dash-card" id="continue-card">
            <h3>Continue Playing</h3>
            <p>Pick up where you left off in your current games.</p>
            <% if (playing && playing.length > 0) { %>
                <div class="library-row">
                    <% playing.forEach(game => { %>
                    <div class="library-card game-card"
                      data-game-id="<%= game.gameId %>"
                      data-name="<%= game.cachedName %>"
                      data-cover="<%= game.cachedCoverUrl %>"
                      data-genres="<%= game.cachedGenres || '' %>"
                      data-rating="<%= game.cachedRating || '' %>"
                      data-release="<%= game.cachedRelease || '' %>"
                    >
                        <div class="game-card-header"> <img
                                src="<%= game.cachedCoverUrl %>"
                                alt="<%= game.cachedName %>"
                                class="game-cover">
                            <p><strong>
                                    <%= game.cachedName %>
                                </strong></p>
                        </div>
                    </div>
                    <% }) %>
                </div>
                <% } else { %>
                <p class="no-items">No games currently playing.</p>
            <% } %>
            <div class="card-spacer"></div> <button
                onclick="window.location.href='/library'"
                class="view-library">View Library</button>
        </div>
    </div>
    <div class="card-rows">
        <div class="dash-card">
            <h3>Recently Played</h3>
            <p>View your recently played games and jump back in with one click.
            </p>
            <p class="recent"> <i class="fa-solid fa-gamepad"></i> <i
                    class="fa-solid fa-gamepad"></i> <i
                    class="fa-solid fa-gamepad"></i> </p>
            <div class="card-spacer"></div>
        </div>
        <div class="dash-card">
            <h3>Recommended for You</h3>
            <p>Based on your gaming history, we think you'll love these titles.
            </p>
            <p class="recommended"> <i class="fa-solid fa-gamepad"></i> <i
                    class="fa-solid fa-gamepad"></i> <i
                    class="fa-solid fa-gamepad"></i> </p>
            <div class="card-spacer"></div>
        </div>
        <div class="dash-card">
            <h3>New Releases</h3>
            <p>Check out the latest games added to our library.</p>
            <p class="releases"> <i class="fa-solid fa-gamepad"></i> <i
                    class="fa-solid fa-gamepad"></i> <i
                    class="fa-solid fa-gamepad"></i> </p>
            <div class="card-spacer"></div>
        </div>
    </div>
</div>

<script>
    let reviewSlideIndex = 1;

    function showReviewSlides(n) {
        const slides = document.getElementsByClassName("review-slide");
        const dots = document.getElementsByClassName("reviewDot");

        if (!slides.length) return;

        if (n > slides.length) reviewSlideIndex = 1;
        if (n < 1) reviewSlideIndex = slides.length;

        for (let i = 0; i < slides.length; i++) {
            slides[i].style.display = "none";
        }

        for (let i = 0; i < dots.length; i++) {
            dots[i].classList.remove("active");
        }

        slides[reviewSlideIndex - 1].style.display = "block";
        dots[reviewSlideIndex - 1].classList.add("active");
    }
    function plusReviewSlides(n) {
        showReviewSlides(reviewSlideIndex += n);
    }
    function currentReviewSlide(n) {
        showReviewSlides(reviewSlideIndex = n);
    }


    showReviewSlides(reviewSlideIndex);
</script>
<%- include('../Partials/footer') %>