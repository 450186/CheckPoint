<%- include('../Partials/header') %>
<div class="sidebar">
  <ul class="nav-list">
    <li class="nav-item"><a href="/dashboard">Dashboard</a></li>
    <li class="nav-item active-link"><a href="/discover"><%= title %></a></li>
    <li class="nav-item"><a href="/library">My Library</a></li>
    <li class="nav-item logout"><a href="/logout">Logout</a></li>
  </ul>
</div>

<div class="main-content">
    <h2 class="title"><%= title %></h2>
    <p>Discover new games and expand your library with our curated selection of titles.</p>
    <% if (errorMessage) { %>
        <p class="error-message"><%= errorMessage %></p> 
    <% } %>
    
    <div class="filter-container" id="filters">
        <div class="filter-item">
            <button data-filter="genres">Genres</button>
        </div>
        <div class="filter-item">
            <button data-filter="platforms">Platforms</button>
        </div>
        <div class="filter-item release-div">
            <button data-filter="release">Release Date</button>
        </div>
        <div class="filter-item">
            <button data-filter="minRating">Rating</button>
        </div>
        <div class="filter-item">
            <button data-filter="sort">Sort</button>
        </div>
        <div class="filter-item">
          <button data-filter="reset">Reset</button>
        </div>
    </div>

    <div class="filter-select-div" hidden id="filter-dropdown"></div>

    <div class="card-rows">
        <% games.forEach(game => { %>
            <div
                class="dash-card game-card"
                data-game-id="<%= game.id %>"
                data-name="<%= game.name %>"
                data-cover="http:<%= game.cover.url.replace('t_thumb','t_cover_big') %>"
                data-genres="<%= game.genres ? game.genres.map(g => g.name).join(', ') : 'Unknown' %>"
                data-rating="<%= game.aggregated_rating ? Math.round(game.aggregated_rating) : '' %>"
                data-release="<%= game.first_release_date ? new Date(game.first_release_date * 1000).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) : 'Unknown' %>"
            >
            <div class="game-card-header">
                <img 
                src="http:<%= game.cover.url.replace("t_thumb", "t_cover_big") %>"
                alt="<%= game.name %>"
                class="game-cover"
                >
                <h3><%= game.name %></h3>
            </div>
            <p><strong>Genre:</strong> <%= game.genres ? game.genres.map(g => g.name).join(', ') : 'Unknown' %></p>
            <% const releaseDate = game.first_release_date
            ? new Date(game.first_release_date * 1000).toLocaleDateString("en-GB", {
                day: "2-digit",
                month: "short",
                year: "numeric"
            }) : "Unknown" %>
            <p><strong>Release Date:</strong> <%= releaseDate %></p>
            <p class="mutedText"><strong>Rating:</strong>
                <%= game.aggregated_rating ? Math.round(game.aggregated_rating) : "N/A" %>
            </p>
            <div class="card-spacer"></div>
            <form action="/library/add" class="library-form" method="POST" onclick="event.stopPropagation()">
                <input type="hidden" name="gameId" value="<%= game.id %>">
                <input type="hidden" name="name" value="<%= game.name %>">
                <input type="hidden" name="coverUrl" value="<%= game.cover.url.replace("t_thumb", "t_cover_big") %>">
                <input type="hidden" name="status" value="wishlist">
                <input type="hidden" name="genres" value="<%= game.genres ? game.genres.map(g => g.name).join(', ') : '' %>">
                <input type="hidden" name="rating" value="<%= game.aggregated_rating ? Math.round(game.aggregated_rating) : '' %>">
                <input type="hidden" name="release" value="<%= releaseDate %>">
                <% if (ownedGames.has(game.id)) { %>
                    <button type="submit" class="add-btn disabled" disabled>Added</button>
                <% } else { %>
                    <button type="submit" class="add-btn">+ Add to Library</button>
                <% } %>
            </form>
        </div>
        <% }) %>
    </div>
    <%
        const currentPage = Number(pageNum || 1)
        const params = new URLSearchParams()

        if(query && query.trim()) {
            params.set('query', query.trim())
        }

        if(filters?.genres?.length) params.set('genres', filters.genres.join(','))
        if(filters?.platforms?.length) params.set('platforms', filters.platforms.join(','))
        if(filters?.minRating) params.set('minRating', String(filters.minRating))
        if(filters?.yearFrom) params.set('yearFrom', String(filters.yearFrom))
        if(filters?.yearTo) params.set('yearTo', String(filters.yearTo))
        if(filters?.sort) params.set('sort', filters.sort)

        const qs = params.toString()
    %>

    <div class="pagination">
    <% if (currentPage > 1) { %>
        <a href="/discover?page=<%= currentPage - 1 %><%= qs ? '&' + qs : '' %>">
        <i class="chevron fa-solid fa-circle-chevron-left"></i>
        </a>
    <% } else { %>
        <span>
        <i class="chevron fa-solid fa-circle-chevron-left disabled"></i>
        </span>
    <% } %>

    <span class="number">Page <%= currentPage %></span>

    <a href="/discover?page=<%= currentPage + 1 %><%= qs ? '&' + qs : '' %>">
        <i class="chevron fa-solid fa-circle-chevron-right"></i>
    </a>
    </div>


</div>
<script>
document.addEventListener("DOMContentLoaded", () => {
  const dropdown = document.getElementById("filter-dropdown");
  const filtersBar = document.getElementById("filters");
  const releaseDiv = document.getElementById("release-div")

  if (!dropdown || !filtersBar) {
    console.log("Missing dropdown or filtersBar", { dropdown, filtersBar });
    return;
  }

const currentSort = "<%= (filters && filters.sort) ? filters.sort : 'release' %>";
const CurrentMinRating = Number("<%= (filters && filters.minRating) ? filters.minRating : 80 %>");
const CurrentYearFrom = "<%= (filters && filters.yearFrom) ? filters.yearFrom : '' %>";
const CurrentYearTo = "<%= (filters && filters.yearTo) ? filters.yearTo : '' %>";
const CurrentGenres = "<%= (filters && filters.genres) ? filters.genres.join(',') : '' %>";
const CurrentPlatforms = "<%= (filters && filters.platforms) ? filters.platforms.join(',') : '' %>";

const availableGenres = <%- JSON.stringify(availableGenres || []) %>;

const popularPlatforms = <%- JSON.stringify(popularPlatforms || []) %>;
const otherPlatforms = <%- JSON.stringify(otherPlatforms || []) %>;

  filtersBar.addEventListener("click", (e) => {
    const btn = e.target.closest("button");
    if (!btn) return;

    const type = btn.dataset.filter;
    console.log("Clicked filter:", type);

    if (type !== "sort" && type !== "minRating" && type !== "yearFrom" && type !== "yearTo" && type !== "genres" && type !== "platforms" && type !== "release" && type !== "reset") {
      dropdown.hidden = true;
      return;
    }
    if(type === 'sort') {
         dropdown.innerHTML = `
      <div>
        <p>Sort By:</p>

        <select id="sort-select">
          <option value="release" ${currentSort === "release" ? "selected" : ""}>Newest</option>
          <option value="rating" ${currentSort === "rating" ? "selected" : ""}>Highest Rating</option>
          <option value="name" ${currentSort === "name" ? "selected" : ""}>Name (A–Z)</option>
        </select>

        <div style="display:flex; margin-top:10px; gap:10px">
          <button type="button" id="apply-sort" class="add-btn">Apply</button>
          <button type="button" id="close-dropdown">Close</button>
        </div>
      </div>
    `;
    }
    if(type === 'minRating') {
        dropdown.innerHTML = `
        <div>
          <p>Minimum Rating:</p>
          <select id="min-rating-select">
            <option value="0" ${CurrentMinRating === 0 ? "selected" : ""}>Any</option>
            <option value="60" ${CurrentMinRating === 60 ? "selected" : ""}>60+</option>
            <option value="70" ${CurrentMinRating === 70 ? "selected" : ""}>70+</option>
            <option value="80" ${CurrentMinRating === 80 ? "selected" : ""}>80+</option>
        </select>
        <div class="filter-actions">
          <button type="button" id="apply-rating" class="add-btn">Apply</button>
          <button type="button" id="close-dropdown">Close</button>
        </div>
      </div>
      `;
    }
    if(type === "release") {
      dropdown.innerHTML = `
      <div>
        <p>Release Date From:</p>
        <input type="month" id="year-from-input" value="${CurrentYearFrom}">
      </div>
      <div>
        <p>Release Date To:</p>
        <input type="month" id="year-to-input" value="${CurrentYearTo}">
      </div>
        <div class="filter-actions">
          <button type="button" id="apply-year-from" class="add-btn">Apply</button>
          <button type="button" id="close-dropdown">Close</button>
        </div>
      `;
    }
    if(type === 'reset') {
      dropdown.innerHTML = `
        <div>
          <p>Are you sure you want to reset all filters?</p>
        </div>
        <div class="filter-actions">
          <button type="button" id="reset-filters" class="add-btn">Reset</button>
          <button type="button" id="close-dropdown">Close</button>
        </div>
      `;
    }
    if(type === 'genres') {
      const selectedGenres = new Set(
        CurrentGenres
          .split(",")
          .map(v => v.trim())
          .filter(Boolean)
      )
      const options = availableGenres.map(genre => `
        <label class="filter-checkbox">
          <input
          type="checkbox"
          class="genre-checkbox"
          value="${genre.id}"
          ${selectedGenres.has(String(genre.id)) ? "checked" : ""}
          />
          ${genre.name}
        </label>
      `).join("");
      dropdown.innerHTML = `
        <div>
          <p>Selected Genres:</p>
          <div class="filter-checkbox-container">
            ${options || "No genres found"}
          </div>
          <div class="filter-actions">
            <button type="button" id="apply-genres" class="add-btn">Apply</button>
            <button type="button" id="clear-genres" class="add-btn">Clear</button>
            <button type="button" id="close-dropdown">Close</button>
          </div>
        </div>
      `;
    }
if(type === 'platforms') {
  const selectedPlatforms = new Set(
    CurrentPlatforms
      .split(",")
      .map(v => v.trim())
      .filter(Boolean)
  );

  const popularOptions = popularPlatforms.map(platform => `
    <label class="filter-checkbox">
      <input
        type="checkbox"
        class="platform-checkbox"
        value="${platform.id}"
        ${selectedPlatforms.has(String(platform.id)) ? "checked" : ""}
      />
      ${platform.name}
    </label>
  `).join("");

  const otherOptions = otherPlatforms.map(platform => `
    <label class="filter-checkbox">
      <input
        type="checkbox"
        class="platform-checkbox"
        value="${platform.id}"
        ${selectedPlatforms.has(String(platform.id)) ? "checked" : ""}
      />
      ${platform.name}
    </label>
  `).join("");

  dropdown.innerHTML = `
    <div>
      <p>Popular Platforms:</p>
      <div class="filter-checkbox-container">
        ${popularOptions || "No platforms found"}
      </div>

      <button type="button" id="toggle-other-platforms" class="toggle-more-btn">
        Show other platforms
      </button>

      <div id="other-platforms-section" class="filter-checkbox-container" hidden>
        ${otherOptions || "No other platforms found"}
      </div>

      <div class="filter-actions">
        <button type="button" id="apply-platforms" class="add-btn">Apply</button>
        <button type="button" id="clear-platforms" class="add-btn">Clear</button>
        <button type="button" id="close-dropdown">Close</button>
      </div>
    </div>
  `;
}


    const rect = btn.getBoundingClientRect();
    dropdown.style.left = `${rect.left + rect.width / 2}px`;
    dropdown.style.top = `${rect.bottom + 10 + window.scrollY}px`;
    dropdown.style.transform = "translateX(-50%)";
    dropdown.hidden = false;
  });

  dropdown.addEventListener("click", (e) => {
    if (e.target.id === "close-dropdown") {
      dropdown.hidden = true;
    }

    if (e.target.id === "apply-sort") {
      const sortVal = document.getElementById("sort-select").value;

      const params = new URLSearchParams(window.location.search);
      params.set("sort", sortVal);
      params.set("page", "1");

      window.location.href = `/discover?${params.toString()}`;
    }
    if(e.target.id === "apply-rating") {
      const ratingVal = document.getElementById("min-rating-select").value;
      const params = new URLSearchParams(window.location.search);
      params.set("minRating", ratingVal);
      params.set("page", "1");
      window.location.href = `/discover?${params.toString()}`;
    }
    if(e.target.id == "apply-year-from") {
      const yearFromVal = document.getElementById("year-from-input").value;
      const yearToVal = document.getElementById("year-to-input").value;
      const params = new URLSearchParams(window.location.search);
      params.set("yearFrom", yearFromVal);
      params.set("yearTo", yearToVal);
      params.set("page", "1");
      window.location.href = `/discover?${params.toString()}`;
    }
    if(e.target.id == "reset-filters") {
      const params = new URLSearchParams(window.location.search);
      params.delete("genres");
      params.delete("platforms");
      params.delete("minRating");
      params.delete("yearFrom");
      params.delete("yearTo");
      params.delete("sort");
      params.set("page", "1");
      window.location.href = `/discover?${params.toString()}`;
    }
    if(e.target.id == "apply-genres") {
      const selected = Array.from(document.querySelectorAll(".genre-checkbox:checked"))
      .map(cb => cb.value)

      const params = new URLSearchParams(window.location.search)
      if(selected.length) params.set("genres", selected.join(","))
      else params.delete("genres")
      params.set("page", "1")
      window.location.href = `/discover?${params.toString()}`
    }
    if(e.target.id == "clear-genres") {
      const params = new URLSearchParams(window.location.search)
      params.delete("genres")
      params.set("page", "1")
      window.location.href = `/discover?${params.toString()}`
    }
    if(e.target.id == "apply-platforms") {
      const selected = Array.from(document.querySelectorAll(".platform-checkbox:checked"))
      .map(cb => cb.value)

      const params = new URLSearchParams(window.location.search)
      if(selected.length) params.set("platforms", selected.join(","))
      else params.delete("platforms")
      params.set("page", "1")
      window.location.href = `/discover?${params.toString()}`
    }
    if(e.target.id == "clear-platforms") {
      const params = new URLSearchParams(window.location.search)
      params.delete("platforms")
      params.set("page", "1")
      window.location.href = `/discover?${params.toString()}`
    }
    if (e.target.id === "toggle-other-platforms") {
      const section = document.getElementById("other-platforms-section");
      if (!section) return;

      const isHidden = section.hasAttribute("hidden");
      if (isHidden) {
        section.removeAttribute("hidden");
        e.target.textContent = "Show fewer platforms";
      } else {
        section.setAttribute("hidden", "");
        e.target.textContent = "Show other platforms";
      }
    }
  });

  document.addEventListener("click", (e) => {
    if (dropdown.hidden) return;
    if (e.target.closest("#filters")) return;
    if (e.target.closest("#filter-dropdown")) return;
    dropdown.hidden = true;
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && !dropdown.hidden) {
      dropdown.hidden = true;

    }
  });
});
</script>
<%- include('../Partials/footer') %>