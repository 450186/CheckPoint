<%- include('../Partials/header') %>

<div class="sidebar">
  <ul class="nav-list">
    <li class="nav-item"><a href="/dashboard">Dashboard</a></li>
    <li class="nav-item"><a href="/discover">Discover</a></li>
    <li class="nav-item active-link"><a href="/library"><%= title %></a></li>
    <li class="nav-item logout"><a href="/logout">Logout</a></li>
  </ul>
</div>

<div class="main-content">
    <h2 class="title"><%= title %></h2>

    <% const sections = [
        {key: "playing", label: "Playing 🟠"},
        {key: "completed", label: "Completed 🟢"},
        {key: "wishlist", label: "Wishlist 🟡"},
        {key: "dropped", label: "Dropped 🔴"}
    ]; %>
<% sections.forEach(section => { %>
    <h3><%= section.label %> (<%= grouped[section.key].length %>)</h3>
    <% if(grouped[section.key].length === 0) { %> 
    <p class="no-items">No items in this section.</p> <% 
    } else { %> 
        <div class="library-row">
    <% grouped[section.key].forEach(item => { %>
        <div class="library-card">
            <div class="game-card-header">
                <img src="<%= item.cachedCoverUrl %>" alt="<%= item.cachedName %>" class="game-cover">
                <h3><%= item.cachedName %></h3>
            </div>
            <% if (item.userRating !== null && item.userRating !== undefined) { %>
                <p class="mutedText"><strong>Your Rating: </strong><%= item.userRating %></p>             
            <% } else { %>
                <p class="mutedText"><strong>Not rated Yet!</strong></p>
            <% } %>
            <div class="card-spacer"></div>
            <form action="/library/status" method="POST" class="status-form"> 
                <input type="hidden" name="gameId" value="<%= item.gameId %>"> 
                <select name="status" onchange="this.form.submit()"> 
                    <option value="playing" <%= item.status === 'playing' ? 'selected' : '' %>>Playing</option> 
                    <option value="completed" <%= item.status === 'completed' ? 'selected' : '' %>>Completed</option> 
                    <option value="wishlist" <%= item.status === 'wishlist' ? 'selected' : '' %>>Wishlist</option> 
                    <option value="dropped" <%= item.status === 'dropped' ? 'selected' : '' %>>Dropped</option> 
                </select> 
            </form>
            <form action="/library/remove" method="POST" class="delete-form">
                <input type="hidden" name="gameId" value="<%= item.gameId %>">
                <button type="submit" class="remove-button">Remove</button>
            </form>
        </div>
    <% }) %>
</div>
<% } %>

<% }) %>
</div>
<%- include('../Partials/footer') %>